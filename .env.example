# Application runtime
# Defaults are safe for local development unless noted otherwise.
NODE_ENV=development
PORT=3000
APP_NAME=safari-social-api
API_PREFIX=/api/v1

# PostgreSQL connection string used by the database layer when running directly on the host.
# Docker Compose overrides DATABASE_URL so the API container reaches the postgres service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safari_social

# PostgreSQL connection pool settings.
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# PostgreSQL container settings used by docker-compose.yml.
# Replace POSTGRES_PASSWORD before sharing or using beyond local development.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=safari_social
POSTGRES_PORT=5432

# Redis connection string used by cache-backed features and rate limiting when running directly on the host.
# Docker Compose overrides REDIS_URL so the API container reaches the redis service.
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Authentication secrets. Replace these placeholders in every real environment.
# Production startup fails if these still use the replace-with-* placeholder format.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

# Browser origins allowed to call the API.
CORS_ORIGIN=http://localhost:3000

# Rate limiting defaults for future request throttling middleware.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Request and upload safety limits.
UPLOAD_MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=info
