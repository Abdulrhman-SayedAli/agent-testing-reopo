# Application runtime
# Defaults are safe for local development unless noted otherwise.
NODE_ENV=development
PORT=3000
APP_NAME=safari-social-api
API_PREFIX=/api/v1

# PostgreSQL connection string used by the database layer.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safari_social

# Redis connection string used by cache-backed features and rate limiting.
REDIS_URL=redis://localhost:6379

# Authentication secrets. Replace these placeholders in every real environment.
# Production startup fails if these still use the replace-with-* placeholder format.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

# Browser origins allowed to call the API.
CORS_ORIGIN=http://localhost:3000

# Rate limiting defaults for future request throttling middleware.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Request and upload safety limits.
UPLOAD_MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=info
